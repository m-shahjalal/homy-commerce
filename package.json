		"cloudinary": "^1.26.3",
		"cors": "^2.8.5",
		"dotenv": "^10.0.0",
		"express": "^4.17.1",
		"express-validator": "^6.12.1",
		"jsonwebtoken": "^8.5.1",
		"mongoose": "^5.13.2",
		"morgan": "^1.10.0",
		"multer": "^1.4.2",
		"stripe": "^8.168.0",
		"winston": "^3.3.3"
	},
